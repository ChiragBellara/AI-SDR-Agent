# Logging
LOG_DIR = "logs"
LOG_LEVEL = "INFO"

# Langsmith Configuration
LANGSMITH_TRACING = True
LANGSMITH_PROJECT=<PROJECT NAME>
LANGSMITH_ENDPOINT = "https://api.smith.langchain.com"
LANGSMITH_API_KEY = <API KEY>

# LLM Configuration
LLM_PROVIDER = "openai"
LLM_TEMPERATURE = "0.75"

# APIs
TAVILY_API_KEY = <API KEY>
OPENAI_API_KEY = <API KEY>
GEMINI_API_KEY = <API KEY>

# Authentication — a long random secret used to verify frontend requests.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
APP_API_KEY = <RANDOM SECRET>

# CORS — the deployed frontend URL (no trailing slash).
# Example: https://your-app.vercel.app
ALLOWED_ORIGIN = http://localhost:5173

# Server port (Render/Railway set this automatically in production).
PORT = 8000